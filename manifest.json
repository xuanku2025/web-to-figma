{
  "manifest_version": 3,
  "name": "Web to Figma",
  "version": "1.0.0",
  "description": "Web to Figma 一键抓取网页并转换为可编辑设计稿，By ZStack（官网：https://www.zstack.io/）。",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "logo/icon16.png",
    "48": "logo/icon48.png",
    "128": "logo/icon128.png"
  },
  "action": {
    "default_title": "Capture page for Figma",
    "default_icon": {
      "16": "logo/icon16.png",
      "48": "logo/icon48.png",
      "128": "logo/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "capture.js",
        "runner.js",
        "logo/icon16.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "quick-capture": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      },
      "description": "快速采集当前页面"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
