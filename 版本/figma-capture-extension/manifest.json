{
  "manifest_version": 3,
  "name": "Web to Figma",
  "version": "1.0.0",
  "description": "Web to Figma 一键抓取网页并转换为可编辑设计稿，By 派大鑫（小红书：https://www.xiaohongshu.com/user/profile/5a2e96aab1da1465364b727b）。",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "logo/icon16.png",
    "48": "logo/icon48.png",
    "128": "logo/icon128.png"
  },
  "action": {
    "default_title": "Capture page for Figma",
    "default_icon": {
      "16": "logo/icon16.png",
      "48": "logo/icon48.png",
      "128": "logo/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "capture.js",
        "runner.js",
        "logo/icon16.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
